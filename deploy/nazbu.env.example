# Copy to nazbu.env and fill in. One per shop server.

# Reuse the SAME value as your backend's DB_URI (womola_be/.env.prod).
# This guarantees the sidecar connects exactly like the backend does.
NAZBU_URI=mongodb://<user>:<pass>@mongo:27017/womoladb?authSource=admin&directConnection=false

# Unique room per shop — this is what isolates shops from each other.
NAZBU_ROOM=shop-42

# A friendly name for this node (shows in the network map).
NAZBU_NAME=shop-42-server

# Womola database name (default womoladb).
NAZBU_DB=womoladb

# 1 = also sync up to the boss's online node when the internet is available.
NAZBU_INTERNET=1
