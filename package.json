{
  "name": "nazbu",
  "version": "0.1.0",
  "description": "Local-first sync engine — keep your existing database (Postgres, MongoDB) running offline and in sync across every device, peer-to-peer, with no server.",
  "keywords": [
    "p2p",
    "local-first",
    "offline-first",
    "sync",
    "sync-engine",
    "database",
    "postgres",
    "postgresql",
    "mongodb",
    "cdc",
    "lan",
    "mdns",
    "peer-to-peer",
    "no-server",
    "crdt"
  ],
  "homepage": "https://djabiridrissou.github.io/nazbu/",
  "bugs": {
    "url": "https://github.com/djabiridrissou/nazbu/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djabiridrissou/nazbu.git"
  },
  "author": "Djabir",
  "license": "MIT",
  "type": "commonjs",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": { "types": "./index.d.ts", "default": "./index.js" },
    "./postgres": { "types": "./nazbu-postgres/store.d.ts", "default": "./nazbu-postgres/store.js" },
    "./mongo": { "types": "./nazbu-mongo/index.d.ts", "default": "./nazbu-mongo/index.js" },
    "./bridge": "./nazbu-mongo/bridge.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "nazbu": "nazbu.js",
    "nazbu-postgres": "nazbu-postgres/run.js",
    "nazbu-mongo": "nazbu-mongo/run.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "adapters.js",
    "nazbu.js",
    "chat.js",
    "stock.js",
    "map.js",
    "transports/",
    "nazbu-mongo/index.js",
    "nazbu-mongo/index.d.ts",
    "nazbu-mongo/bridge.js",
    "nazbu-mongo/stores.js",
    "nazbu-mongo/tenant-sync.js",
    "nazbu-mongo/run.js",
    "nazbu-postgres/store.js",
    "nazbu-postgres/store.d.ts",
    "nazbu-postgres/run.js",
    "assets/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node nazbu.js",
    "chat": "node chat.js",
    "stock": "node stock.js"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "corestore": "^6.18.4",
    "hyperswarm": "^4.17.0"
  },
  "peerDependencies": {
    "pg": "^8",
    "mongodb": ">=5",
    "bson": ">=5"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true },
    "mongodb": { "optional": true },
    "bson": { "optional": true }
  }
}
